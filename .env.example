# =========================================================================
# RentSure Environment Variable Template
# Copy this file to a local .env file to override connection properties.
# =========================================================================

# The active Stellar network passphrase ("testnet" or "public").
# Testnet: "Test SDF Network ; September 2015"
# Mainnet: "Public Global Stellar Network ; October 2015"
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# The active Soroban RPC server endpoint used to query ledgers.
# Testnet: "https://soroban-testnet.stellar.org"
NEXT_PUBLIC_RPC_URL=https://soroban-testnet.stellar.org

# The deployed Rental Agreement Soroban contract public address.
NEXT_PUBLIC_RENTAL_AGREEMENT_ID=CCFPZOCU33AWX2NKX47XD6W5JNYFP7MU57DTQFB5XOOQSJLSSC4PMX25

# The deployed Escrow Soroban contract public address.
NEXT_PUBLIC_ESCROW_ID=CDXKQTPLDDF4RBMJCCTGV2XQ44DCJOY7XZZKPEDJFKQTECSTYHBOI42O

# Stellar.expert explorer root URL used to generate click redirect links.
# Testnet: "https://stellar.expert/explorer/testnet"
NEXT_PUBLIC_EXPLORER_URL=https://stellar.expert/explorer/testnet

# --- Feature Flags ---

# Enables developer tabs and raw simulator panels in the dashboard.
NEXT_PUBLIC_ENABLE_DEV_PANEL=true

# Force mock simulations for local testing even when RPC server is connected.
NEXT_PUBLIC_BYPASS_SIMULATION=false
